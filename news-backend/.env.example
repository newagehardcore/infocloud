# GoDaddy Node.js Hosting build. Per the deploy contract, .env files aren't
# uploaded - set these in the hosting dashboard's environment variables UI
# instead. This file just documents what's needed.

# GoDaddy managed MySQL (outbound network on this platform is restricted to
# HTTP/HTTPS + GoDaddy managed MySQL only - no other DB host/port reaches out)
DB_HOST=
DB_PORT=3306
DB_NAME=
DB_USER=
DB_PASSWORD=

# App port - the platform sets this; 3000 is the local-dev fallback
PORT=3000

# Token required (as X-Admin-Token header or ?token=) for the admin panel
# and all destructive endpoints. Generate one: openssl rand -hex 32
ADMIN_TOKEN=

# Separate secret for the external cron pinger (see /api/internal/tick in
# app.js) - keep distinct from ADMIN_TOKEN so a leaked scheduler URL can't
# reach purge/source-management endpoints. Generate one: openssl rand -hex 32
CRON_SECRET=

# Comma-separated origins allowed by CORS (the static frontend's origin,
# e.g. https://username.github.io). Unset = allow all (local dev only).
ALLOWED_ORIGINS=

# LLM provider: 'groq' here (no local GPU on this platform, and Groq's HTTPS
# API fits the network restriction above). 'ollama' remains for local dev
# on the main/Oracle/Hetzner branch.
LLM_PROVIDER=groq
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Tag cloud tuning (optional)
CACHE_WINDOW_HOURS=72
RECENCY_HALF_LIFE_HOURS=12

# Ingestion tick tuning (optional) - how much work one /api/internal/tick
# call does, kept bounded since the platform's request-timeout isn't documented
SOURCES_PER_TICK=30
ARTICLES_PER_TICK=40
NEWS_ITEM_MAX_AGE_DAYS=14
