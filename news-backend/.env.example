MONGODB_URI=mongodb://USER:PASSWORD@localhost:27017/infocloud?authSource=admin
DB_NAME=infocloud
OLLAMA_API_URL=http://localhost:11434
PORT=5001
MINIFLUX_URL=http://localhost:8080
# Generate in Miniflux: Settings -> API Keys
MINIFLUX_API_KEY=

# Token required (as X-Admin-Token header or ?token=) for the admin panel
# and all destructive endpoints. Generate one: openssl rand -hex 32
ADMIN_TOKEN=

# Comma-separated origins allowed by CORS (the static frontend's origin,
# e.g. https://username.github.io). Unset = allow all (local dev only).
ALLOWED_ORIGINS=

# Tag cloud tuning (optional)
# How far back articles feed the tag cloud
CACHE_WINDOW_HOURS=72
# Mention weight halves every N hours, so fresh stories dominate
RECENCY_HALF_LIFE_HOURS=12
